{
  "name": "Job Application Autofill",
  "description": "Cut time spent applying to jobs by autofilling your information from one place.",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "src/scripts/background.js"
  },
  "action": {
    "default_popup": "public/hello.html",
    "default_icon": "public/hello_extensions.png"
  },
  "side_panel": {
    "default_path": "dist/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["sidePanel", "tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"]
}

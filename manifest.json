{
  "name": "Hello Extensions of the World with React!",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "autofill-extension/src/scripts/background.js"
  },
  "action": {
    "default_popup": "autofill-extension/public/hello.html",
    "default_icon": "autofill-extension/public/hello_extensions.png"
  },
  "side_panel": {
    "default_path": "autofill-extension/dist/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["autofill-extension/src/scripts/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["sidePanel", "tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"]
}
